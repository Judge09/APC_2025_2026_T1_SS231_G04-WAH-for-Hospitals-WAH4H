# ============================================================
# WAH4H — Proxmox VM deployment .env template
# Copy this to wah4h-backend/.env and fill in the values.
# ============================================================

# Django Core
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False

# Set this to your Proxmox VM's IP address (or hostname if you have one)
ALLOWED_HOSTS=localhost,127.0.0.1,<VM_IP>

# Database — Supabase (keep as-is if still using the cloud DB)
DATABASE_NAME=postgres
DATABASE_USER=postgres.hvvlnrhethsmeciuowig
DATABASE_PASSWORD=<your-db-password>
DATABASE_HOST=aws-1-ap-northeast-2.pooler.supabase.com
DATABASE_PORT=5432

# WAH4PC Gateway
WAH4PC_GATEWAY_URL=https://wah4pc.echosphere.cfd
WAH4PC_API_KEY=<your-api-key>
WAH4PC_PROVIDER_ID=<your-provider-uuid>
GATEWAY_AUTH_KEY=<your-gateway-auth-key>

# CORS — must include the VM IP so the frontend can call the backend
# Format: http://<VM_IP>  (no trailing slash)
CORS_ALLOWED_ORIGINS=http://<VM_IP>
CORS_ALLOW_ALL=False

PUBLIC_BASE_URL=http://<VM_IP>

# Email (Gmail SMTP)
EMAIL_HOST_USER=<your-email@gmail.com>
EMAIL_HOST_PASSWORD=<your-gmail-app-password>
